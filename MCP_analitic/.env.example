# Основные пути сервера Auditor Dashboard
AUDITOR_PROJECT_ROOT=C:\projects\MCP_analitic
AUDITOR_SERVER_ENTRY=C:\projects\MCP_analitic\src\server.js
AUDITOR_NODE_PATH=C:\Program Files\nodejs\node.exe
AUDITOR_LOG_DIR=C:\projects\MCP_analitic\logs
AUDITOR_BIN_DIR=C:\projects\MCP_analitic\bin
AUDITOR_CONFIG_DIR=C:\projects\MCP_analitic\logs\state

# HTTP-доступ к дашборду
AUDITOR_DASHBOARD_HOST=0.0.0.0
AUDITOR_DASHBOARD_PORT=3777
PROJECT_WATCH_ALLOWED_SUBNET=192.168.1.

# Сетевые данные и правила ИИ
AUDITOR_RULES_SECRET_FILE=C:\projects\MCP_analitic\secrets\rules-share.json
AUDITOR_TASKS_ROOT=\\HOME_SERGEY\codex$
AUDITOR_RULES_FILE=\\HOME_SERGEY\codex$\FULLSTACK_DEV_HOSTKEY_RULES.md
AUDITOR_RULES_ROLE=Developer

# Логи Codex для карточки лимитов
AUDITOR_CODEX_HOME=C:\Users\user\.codex
